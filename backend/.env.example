# --- Core ---
APP_NAME="Digital Store"
SECRET_KEY="change-me-to-a-long-random-string"
DATABASE_URL="sqlite:///./store.db"          # swap for: mysql+pymysql://user:pass@host/db  or  postgresql+psycopg://...
BASE_URL="http://localhost:8000"

# --- Admin bootstrap (created on first run / seed) ---
ADMIN_EMAIL="admin@store.local"
ADMIN_PASSWORD="admin123"

# --- Delivery / email (Resend-style; leave blank to log to console in dev) ---
RESEND_API_KEY=""
MAIL_FROM="support@order-confirmed.com"
MAIL_FROM_NAME="Digital Store"

# --- Payments ---
# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Crypto (NowPayments-style)
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""
# Manual/test provider auto-confirms orders (dev only)
ENABLE_TEST_PROVIDER="true"

# --- Download security ---
DOWNLOAD_TOKEN_TTL_HOURS="72"
MAX_DOWNLOADS_PER_ITEM="5"
