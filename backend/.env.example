# --- Core ---
APP_NAME="Digital Store"
SECRET_KEY="change-me-to-a-long-random-string"
DATABASE_URL="sqlite:///./store.db"          # swap for: mysql+pymysql://user:pass@host/db  or  postgresql+psycopg://...
BASE_URL="http://localhost:8000"

# --- Admin bootstrap (created on first run / seed) ---
ADMIN_EMAIL="admin@store.local"
ADMIN_PASSWORD="admin123"

# --- Delivery / email (Resend-style; leave blank to log to console in dev) ---
RESEND_API_KEY=""
MAIL_FROM="support@order-confirmed.com"
MAIL_FROM_NAME="Digital Store"

# --- Payments ---
# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Crypto (NowPayments-style)
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""
# Manual/test provider auto-confirms orders (dev only)
ENABLE_TEST_PROVIDER="true"
# Whop embedded checkout (the live checkout used by the Shopify storefronts)
WHOP_API_KEY=""                                   # apik_… (sandbox key from sandbox.whop.com)
WHOP_PRODUCT_ID=""                                # prod_… (inline price is attached to this product)
WHOP_API_BASE="https://api.whop.com"              # or https://sandbox-api.whop.com while testing
WHOP_WEBHOOK_SECRET=""                            # Standard-Webhooks secret; blank = accept unsigned (dev)

# --- Download security ---
DOWNLOAD_TOKEN_TTL_HOURS="72"
MAX_DOWNLOADS_PER_ITEM="5"

# --- Cloudflare R2 (file hosting; a rule's download_url that is an object KEY is served via a signed URL) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ENDPOINT=""                                    # optional override
